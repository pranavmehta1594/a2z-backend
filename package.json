{
  "name": "a2z-shop-backend",
  "version": "1.0.0",
  "description": "Backend API for A2Z Shop e-commerce platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "dev:watch": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
